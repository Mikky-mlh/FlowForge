rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write for tasks if the syncId matches
    match /tasks/{taskId} {
      allow read, write: if true; // In a real app, secure this with auth or syncId validation
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
